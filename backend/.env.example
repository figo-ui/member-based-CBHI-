PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: Local PostgreSQL (development)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_NAME=cbhi_db
DB_SSL=false

# Option B: Supabase (staging / production)
# Replace <project-ref> with your Supabase project reference ID
# Found at: https://supabase.com/dashboard/project/<project-ref>/settings/database
#
# DB_HOST=db.<project-ref>.supabase.co
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=<supabase-db-password>
# DB_NAME=postgres
# DB_SSL=true
#
# Direct connection (for migrations / scripts):
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#
# Pooled connection (for the app — use port 6543 with pgBouncer):
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# FIX MJ-5: NEVER set TYPEORM_SYNCHRONIZE=true in production — use migrations
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false
DB_POOL_MAX=20
DB_POOL_MIN=2

# ── Redis (required for Bull job queue + distributed cache) ───────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=cbhi_redis_pass

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: openssl rand -hex 64
AUTH_JWT_SECRET=replace-me-with-strong-secret-min-32-chars
AUTH_ACCESS_TOKEN_TTL_SECONDS=86400
DIGITAL_CARD_SECRET=replace-me-with-strong-card-secret

# RS256 JWT signing — REQUIRED in production (when NODE_ENV=production)
# Generate an RSA key pair with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then copy the PEM content, replacing literal newlines with \n (escaped), e.g.:
#   AUTH_JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
# When NODE_ENV=production AND AUTH_JWT_PRIVATE_KEY is set, RS256 is used for signing.
# When NODE_ENV != production OR AUTH_JWT_PRIVATE_KEY is unset, HS256 + AUTH_JWT_SECRET is used.
AUTH_JWT_PRIVATE_KEY=
# RSA public key for JWT verification in production (RS256).
# Must correspond to the private key above. Same \n-escaping rules apply.
AUTH_JWT_PUBLIC_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# ── Africa's Talking SMS ──────────────────────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key
AT_SENDER_ID=CBHI

# ── Chapa Payment Gateway ─────────────────────────────────────────────────────
# Get keys at: https://dashboard.chapa.co
# Test key format: CHASECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_SECRET_KEY=CHASECK_TEST-your-test-key
CHAPA_WEBHOOK_SECRET=your-webhook-secret
# Webhook URL: POST https://your-domain.com/api/v1/payments/webhook/chapa
CHAPA_CALLBACK_URL=https://your-domain.com/api/v1/payments/webhook/chapa
# Return URL after payment (backend redirects to cbhi:// deep link for mobile app)
CHAPA_RETURN_URL=https://your-domain.com/api/v1/payments/callback

# ── Google Cloud Vision API ───────────────────────────────────────────────────
GOOGLE_VISION_API_KEY=your_google_vision_api_key
# Fuzzy name match threshold for document verification (0.0–1.0, default 0.75)
VERIFICATION_NAME_MATCH_THRESHOLD=0.75

# ── Google Cloud Storage (for production file uploads) ───────────────────────
GCS_BUCKET=your-cbhi-bucket-name
GCS_PROJECT_ID=your-gcp-project-id
GCS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Firebase Cloud Messaging ──────────────────────────────────────────────────
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk@project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Sentry Error Tracking (FIX MJ-8) ─────────────────────────────────────────
# Get DSN at: https://sentry.io — leave empty to disable
SENTRY_DSN=

# ── Domain (for nginx TLS — FIX ME-6) ────────────────────────────────────────
DOMAIN=your-production-domain.com

# ── App Config ────────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-production-domain.com
CBHI_PREMIUM_PER_MEMBER=120

# ── Research-based 4-tier sliding scale premiums (PMC11936286, Jimma 2022) ────
# Tier 2 — LOW_INCOME: 350 ETB base + 80 ETB per additional adult
CBHI_PREMIUM_LOW=350
# Tier 3 — MIDDLE_INCOME: 500 ETB base + 100 ETB per additional adult (default)
CBHI_PREMIUM_MIDDLE=500
# Tier 4 — HIGH_INCOME: 650 ETB base + 120 ETB per additional adult
CBHI_PREMIUM_HIGH=650
# Additional adult member rate (≥18 yrs) — research mode: 100 ETB/person/year
CBHI_PREMIUM_ADDITIONAL_ADULT=100

# ── Claim enforcement ─────────────────────────────────────────────────────────
CBHI_ANNUAL_CEILING_ETB=10000
CBHI_WAITING_PERIOD_DAYS=30

# ── Indigent scoring thresholds (configurable without code changes) ───────────
INDIGENT_INCOME_THRESHOLD=1000
INDIGENT_FAMILY_SIZE_THRESHOLD=5
INDIGENT_APPROVAL_THRESHOLD=70

# ── Integrations ──────────────────────────────────────────────────────────────
OPENIMIS_BASE_URL=
NATIONAL_ID_API_BASE_URL=
NATIONAL_ID_API_KEY=

DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=am,om,en
